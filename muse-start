#!/bin/bash

# Get the directory where this script is located
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Check if Spotify app OR librespot is NOT running
if ! pgrep -i "Spotify" > /dev/null || ! pgrep -x "librespot" > /dev/null; then
    echo "Starting librespot..."
    librespot &
    sleep 2
fi

# Run muse from the script's directory
exec bun "$SCRIPT_DIR/src/index.tsx"
