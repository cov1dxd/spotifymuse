{
  "name": "muse",
  "version": "0.1.0",
  "description": "A beautiful terminal Spotify client",
  "type": "module",
  "module": "src/index.tsx",
  "bin": {
    "muse": "src/index.tsx"
  },
  "scripts": {
    "start": "bun run src/index.tsx",
    "dev": "bun run --watch src/index.tsx",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "gradient-string": "^3.0.0",
    "ink": "^5.0.1",
    "ink-big-text": "^2.0.0",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "ora": "^8.1.0",
    "react": "^18.3.1",
    "sharp": "^0.33.5",
    "terminal-image": "^3.0.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/gradient-string": "^1.1.6",
    "@types/react": "^18.3.11",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.6.2"
  }
}
