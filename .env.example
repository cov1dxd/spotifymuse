# Copy this file to `.env` and fill in your own Spotify Client ID.
#   cp .env.example .env
#
# Get a Client ID: https://developer.spotify.com/dashboard
#   - Create an app (no secret needed — MUSE uses PKCE)
#   - Add redirect URI:  http://127.0.0.1:8888/callback
#
# Alternatively, leave this unset and MUSE will prompt for the ID on first run.
MUSE_CLIENT_ID=
